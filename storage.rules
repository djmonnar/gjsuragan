rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function adminEmails() {
      return ['sun1562@naver.com'];
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email in adminEmails();
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validTaxCertificateUpload() {
      return request.resource != null
        && request.resource.size <= 8388608
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    match /taxCertificates/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if (isOwner(userId) || isAdmin()) && validTaxCertificateUpload();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
