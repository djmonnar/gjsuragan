rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function adminEmails() {
      return ['sun1562@naver.com'];
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email in adminEmails();
    }

    function isDriverAnon() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function optionalString(data, field, maxLen) {
      return !(field in data.keys())
        || (data[field] is string && data[field].size() <= maxLen);
    }

    function optionalBool(data, field) {
      return !(field in data.keys()) || data[field] is bool;
    }

    function optionalTimestamp(data, field) {
      return !(field in data.keys()) || data[field] is timestamp;
    }

    function optionalFileSize(data, field) {
      return !(field in data.keys())
        || ((data[field] is int || data[field] is float)
          && data[field] >= 0
          && data[field] <= 8388608);
    }

    function nullableTimestamp(data, field) {
      return field in data.keys()
        && (data[field] == null || data[field] is timestamp);
    }

    function safeCount(value) {
      return (value is int || value is float) && value >= 0 && value <= 50;
    }

    function optionalSafeCount(data, field) {
      return !(field in data.keys()) || safeCount(data[field]);
    }

    function safePrice(value) {
      return (value is int || value is float) && value >= 0 && value <= 100000;
    }

    function optionalSafePrice(data, field) {
      return !(field in data.keys()) || safePrice(data[field]);
    }

    function userProfileKeys() {
      return [
        'businessName',
        'email',
        'phone',
        'deliveryPlace',
        'deliveryPlaceDetail',
        'mealTime',
        'defaultLunch',
        'defaultSalad',
        'sameDailyMeal',
        'sameDailyMealExplicit',
        'weekdayMeals',
        'createdAt',
        'updatedAt',
        'privacyConsent',
        'privacyConsentAt',
        'taxInvoiceEnabled',
        'taxInvoiceEmail',
        'taxBusinessNo',
        'taxCashReceiptPhone',
        'taxCertificateName',
        'taxCertificatePath',
        'taxCertificateUrl',
        'taxCertificateContentType',
        'taxCertificateSize',
        'taxCertificateUploadedAt'
      ];
    }

    function userCreateKeys() {
      return [
        'businessName',
        'email',
        'phone',
        'deliveryPlace',
        'deliveryPlaceDetail',
        'mealTime',
        'defaultLunch',
        'defaultSalad',
        'lunchPrice',
        'saladPrice',
        'priceLunch',
        'priceSalad',
        'sameDailyMeal',
        'sameDailyMealExplicit',
        'weekdayMeals',
        'createdAt',
        'updatedAt',
        'privacyConsent',
        'privacyConsentAt',
        'taxInvoiceEnabled',
        'taxInvoiceEmail',
        'taxBusinessNo',
        'taxCashReceiptPhone',
        'taxCertificateName',
        'taxCertificatePath',
        'taxCertificateUrl',
        'taxCertificateContentType',
        'taxCertificateSize',
        'taxCertificateUploadedAt'
      ];
    }

    function withdrawalKeys() {
      return [
        'deleted',
        'disabled',
        'withdrawalRequestedAt',
        'withdrawalRequestedBy',
        'updatedAt'
      ];
    }

    function taxProfileKeys() {
      return [
        'taxInvoiceEnabled',
        'taxInvoiceEmail',
        'taxBusinessNo',
        'taxCashReceiptPhone',
        'taxCertificateName',
        'taxCertificatePath',
        'taxCertificateUrl',
        'taxCertificateContentType',
        'taxCertificateSize',
        'taxCertificateUploadedAt',
        'updatedAt'
      ];
    }

    function validWeekdayMeals(data) {
      return !(('weekdayMeals' in data.keys()))
        || (
          data.weekdayMeals is map
          && data.weekdayMeals.keys().hasOnly(['mon', 'tue', 'wed', 'thu', 'fri'])
          && (!('mon' in data.weekdayMeals.keys()) || validMealPair(data.weekdayMeals.mon))
          && (!('tue' in data.weekdayMeals.keys()) || validMealPair(data.weekdayMeals.tue))
          && (!('wed' in data.weekdayMeals.keys()) || validMealPair(data.weekdayMeals.wed))
          && (!('thu' in data.weekdayMeals.keys()) || validMealPair(data.weekdayMeals.thu))
          && (!('fri' in data.weekdayMeals.keys()) || validMealPair(data.weekdayMeals.fri))
        );
    }

    function validMealPair(meal) {
      return meal is map
        && meal.keys().hasOnly(['lunch', 'salad'])
        && (!('lunch' in meal.keys()) || safeCount(meal.lunch))
        && (!('salad' in meal.keys()) || safeCount(meal.salad));
    }

    function validUserProfile(data) {
      return optionalString(data, 'businessName', 80)
        && optionalString(data, 'email', 160)
        && optionalString(data, 'phone', 40)
        && optionalString(data, 'deliveryPlace', 200)
        && optionalString(data, 'deliveryPlaceDetail', 200)
        && optionalString(data, 'mealTime', 20)
        && optionalSafeCount(data, 'defaultLunch')
        && optionalSafeCount(data, 'defaultSalad')
        && optionalSafePrice(data, 'lunchPrice')
        && optionalSafePrice(data, 'saladPrice')
        && optionalSafePrice(data, 'priceLunch')
        && optionalSafePrice(data, 'priceSalad')
        && optionalBool(data, 'sameDailyMeal')
        && optionalBool(data, 'sameDailyMealExplicit')
        && optionalBool(data, 'privacyConsent')
        && optionalBool(data, 'taxInvoiceEnabled')
        && optionalString(data, 'taxInvoiceEmail', 160)
        && optionalString(data, 'taxBusinessNo', 40)
        && optionalString(data, 'taxCashReceiptPhone', 40)
        && optionalString(data, 'taxCertificateName', 300)
        && optionalString(data, 'taxCertificatePath', 500)
        && optionalString(data, 'taxCertificateUrl', 2000)
        && optionalString(data, 'taxCertificateContentType', 80)
        && optionalFileSize(data, 'taxCertificateSize')
        && validWeekdayMeals(data)
        && optionalTimestamp(data, 'createdAt')
        && optionalTimestamp(data, 'updatedAt')
        && optionalTimestamp(data, 'privacyConsentAt')
        && optionalTimestamp(data, 'taxCertificateUploadedAt');
    }

    function validUserCreate(userId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly(userCreateKeys())
        && validUserProfile(request.resource.data)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.privacyConsent == true
        && request.resource.data.privacyConsentAt == request.time;
    }

    function validUserUpdate(userId) {
      return isOwner(userId)
        && (!('deleted' in resource.data.keys()) || resource.data.deleted == false)
        && (!('disabled' in resource.data.keys()) || resource.data.disabled == false)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userProfileKeys())
        && validUserProfile(request.resource.data)
        && (!('email' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.email == request.auth.token.email);
    }

    function validUserTaxProfileUpdate(userId) {
      return isOwner(userId)
        && (!('deleted' in resource.data.keys()) || resource.data.deleted == false)
        && (!('disabled' in resource.data.keys()) || resource.data.disabled == false)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(taxProfileKeys());
    }

    function taxCertificateDocKeys() {
      return [
        'taxInvoiceEnabled',
        'taxInvoiceEmail',
        'taxBusinessNo',
        'taxCashReceiptPhone',
        'taxCertificateName',
        'taxCertificatePath',
        'taxCertificateUrl',
        'taxCertificateContentType',
        'taxCertificateSize',
        'taxCertificateUploadedAt',
        'userId',
        'customerName',
        'phone',
        'email',
        'updatedBy',
        'createdAt',
        'updatedAt'
      ];
    }

    function validTaxCertificateDoc(userId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly(taxCertificateDocKeys())
        && (!('userId' in request.resource.data.keys()) || request.resource.data.userId == userId);
    }

    function validUserWithdrawal(userId) {
      return isOwner(userId)
        && (!('deleted' in resource.data.keys()) || resource.data.deleted == false)
        && (!('disabled' in resource.data.keys()) || resource.data.disabled == false)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(withdrawalKeys())
        && request.resource.data.deleted == true
        && request.resource.data.disabled == true
        && request.resource.data.withdrawalRequestedAt == request.time
        && request.resource.data.withdrawalRequestedBy == userId
        && request.resource.data.updatedAt == request.time;
    }

    function orderKeys() {
      return ['uid', 'targetDate', 'lunchCount', 'saladCount', 'note', 'selfHoliday', 'submittedAt', 'updatedAt'];
    }

    function orderDateUnlocked(date) {
      return !exists(/databases/$(database)/documents/orderLocks/$(date));
    }

    function validOrderWrite(date, userId) {
      return isOwner(userId)
        && orderDateUnlocked(date)
        && request.resource.data.keys().hasOnly(orderKeys())
        && request.resource.data.uid == userId
        && request.resource.data.targetDate == date
        && safeCount(request.resource.data.lunchCount)
        && safeCount(request.resource.data.saladCount)
        && optionalString(request.resource.data, 'note', 500)
        && optionalBool(request.resource.data, 'selfHoliday')
        && (!('selfHoliday' in request.resource.data.keys())
          || request.resource.data.selfHoliday == false
          || (request.resource.data.lunchCount == 0 && request.resource.data.saladCount == 0))
        && request.resource.data.submittedAt == request.time
        && optionalTimestamp(request.resource.data, 'updatedAt');
    }

    function validOrderCreate(date, userId) {
      return validOrderWrite(date, userId);
    }

    function validOrderUpdate(date, userId) {
      return (!('uid' in resource.data.keys()) || resource.data.uid == userId)
        && validOrderWrite(date, userId);
    }

    function validOrderDelete(date, userId) {
      return isOwner(userId)
        && orderDateUnlocked(date)
        && (!('uid' in resource.data.keys()) || resource.data.uid == userId);
    }

    function eventOrderKeys() {
      return [
        'businessName',
        'contactPhone',
        'place',
        'placeDetail',
        'eventDate',
        'eventTime',
        'eventTimeType',
        'menuText',
        'items',
        'requestNote',
        'paymentCash',
        'paymentTransfer',
        'paymentCard',
        'status',
        'source',
        'createdAt',
        'privacyConsent',
        'companyWebsite'
      ];
    }

    function exactlyOnePaymentMethod(data) {
      return (
        data.paymentCash == true
        && data.paymentTransfer == false
        && data.paymentCard == false
      ) || (
        data.paymentCash == false
        && data.paymentTransfer == true
        && data.paymentCard == false
      ) || (
        data.paymentCash == false
        && data.paymentTransfer == false
        && data.paymentCard == true
      );
    }

    function validPublicEventOrder() {
      return request.auth == null
        && request.resource.data.keys().hasOnly(eventOrderKeys())
        && request.resource.data.businessName is string
        && request.resource.data.businessName.size() > 0
        && request.resource.data.businessName.size() <= 80
        && request.resource.data.contactPhone is string
        && request.resource.data.contactPhone.matches('^0[0-9\\- ]{7,20}$')
        && request.resource.data.place is string
        && request.resource.data.place.size() > 0
        && request.resource.data.place.size() <= 160
        && optionalString(request.resource.data, 'placeDetail', 200)
        && request.resource.data.eventDate is string
        && request.resource.data.eventDate.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && request.resource.data.eventTime is string
        && request.resource.data.eventTime.size() > 0
        && request.resource.data.eventTime.size() <= 40
        && request.resource.data.eventTimeType in ['preset', 'custom']
        && request.resource.data.menuText is string
        && request.resource.data.menuText.size() > 0
        && request.resource.data.menuText.size() <= 500
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 20
        && optionalString(request.resource.data, 'requestNote', 500)
        && request.resource.data.paymentCash is bool
        && request.resource.data.paymentTransfer is bool
        && request.resource.data.paymentCard is bool
        && exactlyOnePaymentMethod(request.resource.data)
        && request.resource.data.status == 'new'
        && request.resource.data.source == 'publicEventPage'
        && request.resource.data.createdAt == request.time
        && request.resource.data.privacyConsent == true
        && request.resource.data.companyWebsite is string
        && request.resource.data.companyWebsite.size() == 0;
    }

    function changeRequestKeys() {
      return [
        'customerId',
        'customerName',
        'phone',
        'type',
        'title',
        'before',
        'after',
        'memo',
        'status',
        'createdAt',
        'readAt',
        'handledAt',
        'adminReply',
        'answeredAt',
        'notificationStatus',
        'notifiedAt',
        'notificationAttempts',
        'urgent'
      ];
    }

    function validChangeRequestCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly(changeRequestKeys())
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() <= 80
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 40
        && request.resource.data.type in ['schedule_change', 'address_change', 'pause', 'memo', 'etc']
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && optionalString(request.resource.data, 'before', 500)
        && optionalString(request.resource.data, 'after', 500)
        && optionalString(request.resource.data, 'memo', 1000)
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time
        && nullableTimestamp(request.resource.data, 'readAt')
        && request.resource.data.readAt == null
        && nullableTimestamp(request.resource.data, 'handledAt')
        && request.resource.data.handledAt == null
        && (!('adminReply' in request.resource.data.keys()) || request.resource.data.adminReply == '')
        && (!('answeredAt' in request.resource.data.keys()) || request.resource.data.answeredAt == null)
        && request.resource.data.notificationStatus == 'pending'
        && nullableTimestamp(request.resource.data, 'notifiedAt')
        && request.resource.data.notifiedAt == null
        && request.resource.data.notificationAttempts == 0
        && request.resource.data.urgent == false;
    }

    function adminPushTokenKeys() {
      return [
        'token',
        'userEmail',
        'userAgent',
        'platform',
        'enabled',
        'createdAt',
        'updatedAt',
        'disabledAt',
        'disabledReason'
      ];
    }

    function validAdminPushTokenWrite() {
      return isAdmin()
        && request.resource.data.keys().hasOnly(adminPushTokenKeys())
        && request.resource.data.token is string
        && request.resource.data.token.size() > 20
        && request.resource.data.token.size() <= 4096
        && request.resource.data.userEmail == request.auth.token.email
        && optionalString(request.resource.data, 'userAgent', 500)
        && optionalString(request.resource.data, 'platform', 120)
        && request.resource.data.enabled is bool
        && optionalTimestamp(request.resource.data, 'createdAt')
        && optionalTimestamp(request.resource.data, 'updatedAt')
        && optionalTimestamp(request.resource.data, 'disabledAt')
        && optionalString(request.resource.data, 'disabledReason', 120);
    }

    function validDriverCustomerUpdate() {
      return isDriverAnon()
        && resource.data.isDirect == true
        && request.resource.data.isDirect == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['remain', 'deliveredDates', 'status'])
        && optionalSafeCount(request.resource.data, 'remain')
        && request.resource.data.deliveredDates is list
        && request.resource.data.deliveredDates.size() <= 100
        && request.resource.data.status in ['active', 'pause', 'end'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || validUserCreate(userId);
      allow update: if isAdmin() || validUserUpdate(userId) || validUserTaxProfileUpdate(userId) || validUserWithdrawal(userId);
      allow delete: if isAdmin();
    }

    match /userPrivate/{userId} {
      allow read, write: if isAdmin();
    }

    match /taxCertificates/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if validTaxCertificateDoc(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /orders/{date}/items/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || validOrderCreate(date, userId);
      allow update: if isAdmin() || validOrderUpdate(date, userId);
      allow delete: if isAdmin() || validOrderDelete(date, userId);
    }

    match /orderLocks/{date} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /orderDefaultSnapshots/{date}/items/{userId} {
      allow read, write: if isAdmin();
    }

    match /orderLogs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /mealMenus/{date} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /mealOcrJobs/{jobId} {
      allow read, write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /settlements/{monthId}/items/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /eventOrders/{orderId} {
      allow create: if validPublicEventOrder();
      allow read, update, delete: if isAdmin();
    }

    match /changeRequests/{requestId} {
      allow read: if isAdmin() || (signedIn() && resource.data.customerId == request.auth.uid);
      allow create: if validChangeRequestCreate();
      allow update, delete: if isAdmin();
    }

    match /adminPushTokens/{tokenId} {
      allow read, delete: if isAdmin();
      allow create, update: if validAdminPushTokenWrite();
    }

    match /adminPushTests/{testId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /invalidPushTokens/{document=**} {
      allow read, write: if isAdmin();
    }

    match /deliveryCoords/{document=**} {
      allow read, write: if isAdmin() || isDriverAnon();
    }

    match /customers/{document=**} {
      allow read: if isAdmin() || (isDriverAnon() && resource.data.isDirect == true);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || validDriverCustomerUpdate();
    }

    match /imwebCancelLogs/{document=**} {
      allow read, write: if isAdmin();
    }

    match /editorStates/{document=**} {
      allow read, write: if isAdmin();
    }

    match /monthlyMenus/{document=**} {
      allow read, write: if isAdmin();
    }

    match /lunchboxMenus/{document=**} {
      allow read, write: if isAdmin();
    }

    match /aiMenuDrafts/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
