rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'sun1562@naver.com';
    }

    match /customers/{document=**} {
      allow read, write: if isAdmin();
    }

    match /imwebCancelLogs/{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
    }

    match /orders/{date}/items/{userId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
    }

    match /mealMenus/{date} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /editorStates/{docId} {
      allow read, write: if isAdmin();
    }

    match /monthlyMenus/{monthId} {
      allow read, write: if isAdmin();
    }

    match /lunchboxMenus/{monthId} {
      allow read, write: if isAdmin();
    }

    match /aiMenuDrafts/{monthId} {
      allow read, write: if isAdmin();
    }
  }
}
